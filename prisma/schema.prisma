generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Study sessions you log daily
model StudySession {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  minutes   Int
  topic     String
  domain    String
  notes     String?  @db.Text
  createdAt DateTime @default(now())
}

// Practice exams you take
model PracticeExam {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  score         Int
  source        String
  questionCount Int      @default(10)
  notes         String?
  createdAt     DateTime @default(now())
}

// Your concept notes (written by you)
model ConceptNote {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  domain      String
  examWeight  String
  topicNumber Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Complete curriculum (45 topics for SAA-C03)
model CurriculumTopic {
  id             String   @id @default(cuid())
  topicNumber    Int      @unique
  title          String
  domain         String   // Foundation, Security, Resilient, Performance, Cost
  subdomain      String?
  keyServices    String[] // ["IAM", "S3"]
  estimatedHours Int      @default(2)
  examWeight     String   // High, Medium, Low, Prerequisite
  isCompleted    Boolean  @default(false)
  completedAt    DateTime?
  studyMinutes   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Projects you build
model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  status      String   // Planning, In Progress, Deployed, Documented
  liveUrl     String?
  githubUrl   String?
  screenshot  String?
  awsServices String[] // ["S3", "CloudFront", "Lambda"]
  topicNumbers Int[]   // Which topics this project proves
  startedAt   DateTime?
  deployedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Study streak tracking
model StudyStreak {
  id        String   @id @default(cuid())
  date      DateTime @unique
  minutes   Int
  completed Boolean  @default(true)
}