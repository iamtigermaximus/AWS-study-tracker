generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Study sessions you log daily
model StudySession {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  minutes   Int
  topic     String
  domain    String
  notes     String?  @db.Text
  createdAt DateTime @default(now())
}

// Practice exams you take
model PracticeExam {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  score         Int
  source        String
  questionCount Int      @default(10)
  notes         String?
  createdAt     DateTime @default(now())
}

// Your concept notes (written by you)
model ConceptNote {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  domain      String
  examWeight  String
  topicNumber Int?      // Simply store the lesson number, no relation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Main curriculum - 387 Maarek lessons
model CurriculumTopic {
  id             String   @id @default(cuid())
  topicNumber    Int      @unique        // 1-387 (continuous)
  title          String
  domain         String                  // Foundation, Security, Resilient, Performance, Cost
  subdomain      String?                 // Section name from course
  keyServices    String[]                // AWS services covered
  estimatedHours Float    @default(2)    // Can be fractional (e.g., 0.5 for short videos)
  examWeight     String                  // High, Medium, Low, Prerequisite
  
  // Progress tracking
  isCompleted    Boolean  @default(false)
  completedAt    DateTime?
  studyMinutes   Int      @default(0)
  
  // Maarek course specific fields
  description    String?  @db.Text       // What to expect from this lesson
  duration       String?                 // Video length (HH:MM:SS)
  lessonNumber   Int?     @unique        // Udemy lesson number (1-387)
  sectionNumber  Int?                    // Udemy section number (1-33)
  sectionName    String?                 // Udemy section name
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Projects you build
model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @db.Text
  status      String   // Planning, In Progress, Deployed, Documented
  liveUrl     String?
  githubUrl   String?
  screenshot  String?
  awsServices String[]
  topicNumbers Int[]    // Changed from topicIds to topicNumbers (1-387)
  startedAt   DateTime?
  deployedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Study streak tracking
model StudyStreak {
  id        String   @id @default(cuid())
  date      DateTime @unique
  minutes   Int
  completed Boolean  @default(true)
}